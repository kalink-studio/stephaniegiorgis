## Payload / Next runtime
PAYLOAD_SECRET=replace-with-a-long-random-secret
PREVIEW_SECRET=replace-with-a-long-random-secret
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3000

## Database
## DATABASE_URL: pooled runtime connection
## DATABASE_URL_DIRECT: direct migration / maintenance connection
DATABASE_URL=postgres://user:password@host/db?sslmode=require
DATABASE_URL_DIRECT=postgres://user:password@host/db?sslmode=require

## S3 storage
S3_ENDPOINT=https://s3.pub1.infomaniak.cloud
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=replace-with-s3-access-key
S3_SECRET_ACCESS_KEY=replace-with-s3-secret-key
S3_BUCKET=stephaniegiorgis-dev

## Revalidation / integrations
REVALIDATE_SECRET=replace-with-a-long-random-secret
RESEND_KEY=re_replace_with_resend_key
